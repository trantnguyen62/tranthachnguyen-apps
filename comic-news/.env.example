# Comic News — environment variables
# Copy to .env or pass directly to the process / docker run.

# Port the Express server listens on.
PORT=5187

# Canonical base URL used in sitemap.xml. No trailing slash.
BASE_URL=https://comic-news.tranthachnguyen.com

# Origin allowed by the CORS policy.
# In development set to the Vite dev-server origin (e.g. http://localhost:5187).
# In production this should match BASE_URL.
ALLOWED_ORIGIN=https://comic-news.tranthachnguyen.com
