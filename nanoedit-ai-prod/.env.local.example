# URL of the gemini-web-proxy instance (Puppeteer-based Gemini automation)
# See: https://github.com/tranthachnguyen/gemini-web-proxy
GEMINI_PROXY_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins for the proxy server.
# Defaults to the production domain; add http://localhost:5173 for local dev.
# ALLOWED_ORIGINS=https://photoedit.tranthachnguyen.com,http://localhost:5173

# URL of the proxy server as seen by the browser (used by the Vite frontend).
# Only needed when overriding the default port (5174).
# VITE_PROXY_URL=http://localhost:5174
