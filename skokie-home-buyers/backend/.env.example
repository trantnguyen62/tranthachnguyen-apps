# Server Configuration
PORT=5188

# Email Notifications (Optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
NOTIFY_EMAIL=your-notification-email@gmail.com

# Property Valuation API Configuration
# Choose one provider: 'zillow', 'redfin', or 'attom'
PROPERTY_API_PROVIDER=zillow

# RapidAPI Key (for Zillow or Redfin)
# Get your key at: https://rapidapi.com/
RAPID_API_KEY=your-rapidapi-key-here

# Attom Data API Key (alternative)
# Get your key at: https://api.developer.attomdata.com/
ATTOM_API_KEY=your-attom-api-key-here

# Notes:
# - Without API keys, the system will use mock data for demonstration
# - RapidAPI has free tiers for testing
# - Zillow API: https://rapidapi.com/apimaker/api/zillow-com1
# - Redfin API: https://rapidapi.com/s.mahmoud97/api/redfin-com-data
# - Realtor.com API: https://rapidapi.com/datascraper/api/realtor-data
